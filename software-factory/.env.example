# Environment Configuration
# Copy this file to .env and fill in your values

# OpenRouter API Key (required)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Qdrant Configuration
#QDRANT_HOST=localhost
#QDRANT_PORT=6333

VECTOR_DB_TYPE=chromadb
CHROMA_DB_PATH=./chroma_db

# Application Settings
LOG_LEVEL=INFO
DEBUG=false
PROJECT_OUTPUT_DIR=./output

# Model Configuration (optional - uses defaults if not set)
# Planning/Architecture model
#deepseek/deepseek-chat
PLANNING_MODEL_NAME=qwen/qwen3.6-plus:free
PLANNING_MODEL_MAX_TOKENS=8192
PLANNING_MODEL_TEMPERATURE=0.3

# Code generation model
CODE_GENERATION_MODEL_NAME=qwen/qwen3.6-plus:free
CODE_GENERATION_MODEL_MAX_TOKENS=8192
CODE_GENERATION_MODEL_TEMPERATURE=0.2

# Conversational/Q&A model
CONVERSATIONAL_MODEL_NAME=qwen/qwen3.6-plus:free
CONVERSATIONAL_MODEL_MAX_TOKENS=500
CONVERSATIONAL_MODEL_TEMPERATURE=0.7

# Log analysis model
LOG_ANALYSIS_MODEL_NAME=minimax/minimax-m2.5:free
LOG_ANALYSIS_MODEL_MAX_TOKENS=2048
LOG_ANALYSIS_MODEL_TEMPERATURE=0.1

# Summarization model
#openai/gpt-4o-mini
SUMMARIZATION_MODEL_MAX_TOKENS=2048
SUMMARIZATION_MODEL_NAME=openai/gpt-oss-120b:free
SUMMARIZATION_MODEL_TEMPERATURE=0.3

# Cost Governance (optional - uses defaults if not set)
MAX_TOKENS_PER_SESSION=500000
MAX_COST_PER_SESSION=10.0
